{
  "name": "mail",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/mail/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "typecheck": {
      "cache": true,
      "inputs": ["production", "^production", { "externalDependencies": ["typescript"] }],
      "executor": "nx:run-commands",
      "options": {
        "cwd": "libs/mail",
        "command": "tsc --noEmit -p tsconfig.lib.json"
      }
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": {
        "command": "email dev --dir src/templates --port 3030",
        "cwd": "{projectRoot}"
      }
    },
    "export": {
      "executor": "nx:run-commands",
      "options": {
        "command": "email export --dir src/templates",
        "cwd": "{projectRoot}"
      }
    }
  }
}
