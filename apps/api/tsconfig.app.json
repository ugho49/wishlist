{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "types": ["node"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "jsx": "react-jsx"
  },
  "exclude": ["src/**/*.int-spec.ts", "src/**/*.spec.ts"],
  "include": ["src/**/*.ts", "src/**/*.tsx", "codegen.ts"]
}
